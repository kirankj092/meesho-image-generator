# ============================================================
# Meesho Image Generator — Root .htaccess
# ============================================================

Options -Indexes
Options -ExecCGI

# ---- Security Headers ----
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ---- Block direct access to PHP config files ----
<FilesMatch "^(config\.php|config\.sample\.php|\.env)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ---- Block access to dot files ----
<FilesMatch "^\.(git|htaccess|htpasswd|DS_Store)">
    Order allow,deny
    Deny from all
</FilesMatch>

# ---- Block shell / dangerous extensions ----
<FilesMatch "\.(sh|bash|py|rb|pl|cgi|sql|bak|log|swp)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ---- Clean URLs ----
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /apps/meesho-image-generator/

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Remove .php extension
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^([^\.]+)$ $1.php [NC,L]
</IfModule>
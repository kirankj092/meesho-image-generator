# ============================================================
# Meesho Image Generator — Root .htaccess
# ============================================================

Options -Indexes
Options -ExecCGI

# ---- Security Headers ----
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ---- Block direct access to PHP config files ----
<FilesMatch "^(config\.php|config\.sample\.php|\.env)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ---- Block access to dot files ----
<FilesMatch "^\.(git|htaccess|htpasswd|DS_Store)">
    Order allow,deny
    Deny from all
</FilesMatch>

# ---- Block dangerous extensions ----
<FilesMatch "\.(sh|bash|py|rb|pl|cgi|sql|bak|log|swp)$">
    Order allow,deny
    Deny from all
</FilesMatch>